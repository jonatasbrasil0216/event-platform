{
  "name": "@event-platform/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/local/server.ts",
    "test": "vitest run",
    "db:migrate": "tsx src/scripts/migrate.ts",
