    "deploy": "serverless deploy",
    "package:aws": "serverless package"
  },
  "dependencies": {
    "@event-platform/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "openai": "^4.104.0",
    "serverless-http": "^4.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "esbuild": "0.25.10",
    "serverless": "3.40.0",
    "serverless-esbuild": "1.55.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
