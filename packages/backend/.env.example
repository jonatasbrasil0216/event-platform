# MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/event_platform

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=replace-with-a-long-secret

# JWT expiration (e.g., '7d')
JWT_EXPIRES_IN=7d

# OpenAI API key for AI features
OPENAI_API_KEY=your-openai-api-key-here

# VPC configuration (only required for real AWS deploys)
VPC_ID=your-vpc-id
SUBNET_ID_1=your-subnet-id-1
SUBNET_ID_2=your-subnet-id-2