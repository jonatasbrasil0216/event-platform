# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/event_platform

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=

# JWT expiration (e.g., '7d')
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:3001

# Optional: comma-separated origins for CORS in production (defaults to http://localhost:3000 locally).
# Required for a deployed frontend talking to Lambda — set the same variable in your shell when running `pnpm deploy` in packages/backend.
# CORS_ORIGIN=https://your-frontend.example.com
